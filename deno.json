{
  "tasks": {
    "sync": "slash-up sync",
    "sync:dev": "slash-up sync -e development",
    "generate": "prisma generate",
    "start": "cd src && bun run ./index.js",
    "dev": "bun --watch --no-clear-screen run ./src/index.js",
    "check": "tsc --noEmit",
    "prettier:check": "prettier ./src --check",
    "eslint:check": "eslint ./src/**/*.ts",
    "prettier:fix": "prettier ./src --write",
    "eslint:fix": "eslint ./src/**/*.ts --fix",
    "lint": "prettier ./src --check && eslint ./src/**/*.ts && tsc --noEmit",
    "lint:fix": "prettier ./src --write && eslint ./src/**/*.ts --fix"
  },
  "imports": {
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^7.8.0",
    "@prisma/client": "npm:@prisma/client@^7.8.0",
    "prisma": "npm:prisma@^7.8.0"
  },
}
