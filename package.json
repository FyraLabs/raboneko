{
  "name": "raboneko",
  "version": "0.32.2",
  "description": "Raboneko.",
  "main": "src/index.js",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "sync": "slash-up sync",
    "sync:dev": "slash-up sync -e development",
    "generate": "prisma generate",
    "start": "cd src && bun run ./index.js",
    "dev": "bun --watch --no-clear-screen run ./src/index.js",
    "check": "tsc --noEmit",
    "prettier:check": "prettier ./src --check",
    "eslint:check": "eslint ./src/**/*.ts",
    "prettier:fix": "prettier ./src --write",
    "eslint:fix": "eslint ./src/**/*.ts --fix",
    "lint": "bun run prettier:check && bun run eslint:check && bun run check",
    "lint:fix": "bun run prettier:fix && bun run eslint:fix"
  },
  "dependencies": {
    "@moonshine-ai/moonshine-js": "^0.1.29",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@ricky0123/vad-web": "^0.0.30",
    "@sentry/node": "^10.51.0",
    "bullmq": "^5.76.2",
    "cat-loggr": "^1.2.2",
    "dayjs": "^1.11.19",
    "discord-api-types": "^0.38.47",
    "discord.js": "^14.26.4",
    "fastify": "^5.8.5",
    "mediabunny": "^1.43.1",
    "onnxruntime-web": "1.22.0",
    "parse-duration": "^2.1.6",
    "prisma": "^7.8.0",
    "slash-create": "^6.8.1",
    "webcodecs-polyfill": "^1.0.1"
  },
  "devDependencies": {
    "@sentry/cli": "^3.4.1",
    "@types/bun": "^1.3.13",
    "@types/express": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.2.1",
    "eslint-config-dmitmel": "github:dmitmel/eslint-config-dmitmel",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "slash-up": "^1.4.2",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@seydx/node-av-darwin-arm64",
    "@seydx/node-av-linux-x64",
    "node-av"
  ]
}
